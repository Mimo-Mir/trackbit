# Trackbit Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Never expose this client-side
NEXT_PUBLIC_SUPABASE_DEFAULT_SCHEMA=public
NEXT_PUBLIC_SUPABASE_TRACKBIT_SCHEMA=trackbit
NEXT_PUBLIC_TRACKBIT_STORAGE_BUCKET=trackbit-assets

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Trackbit

# ─── Optional: Analytics ────────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
